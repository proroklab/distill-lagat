{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "interface-lacam3",
      "displayName": "Interface LaCAM3",
      "description": "Configure LaCAM3 Python interface library",
      "binaryDir": "${sourceDir}/../../../../build/interface-lacam3",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "interface-lagat",
      "displayName": "Interface LaGAT",
      "description": "Configure LaGAT Python interface library",
      "binaryDir": "${sourceDir}/../../../../build/interface-lagat",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "interface-lacam3",
      "configurePreset": "interface-lacam3"
    },
    {
      "name": "interface-lagat",
      "configurePreset": "interface-lagat"
    }
  ]
}
